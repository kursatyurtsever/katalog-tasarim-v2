"use client";

import { useCatalogStore, Slot as SlotType } from "@/store/useCatalogStore";
import { useState } from "react";

interface SlotProps {
  slot: SlotType;
  pageNumber: number;
  slotIndex: number;
}

const splitPrice = (price: any) => {
  if (!price) return { main: "0", decimal: "00" };
  const str = String(price).replace(".", ",");
  const parts = str.split(",");
  const main = parts[0] || "0";
  const decimal = parts[1] ? (parts[1].padEnd(2, "0").slice(0, 2)) : "00";
  return { main, decimal };
};

export function Slot({ slot, pageNumber, slotIndex }: SlotProps) {
  const swapSlotContents = useCatalogStore((state) => state.swapSlotContents);
  const [isOver, setIsOver] = useState(false);

  // Native Drag & Drop İşleyicileri
  const handleDragStart = (e: React.DragEvent) => {
    e.dataTransfer.setData("sourcePage", String(pageNumber));
    e.dataTransfer.setData("sourceIndex", String(slotIndex));
    e.dataTransfer.effectAllowed = "move";
  };

  const handleDragOver = (e: React.DragEvent) => {
    e.preventDefault();
    setIsOver(true);
  };

  const handleDragLeave = () => setIsOver(false);

  const handleDrop = (e: React.DragEvent) => {
    e.preventDefault();
    setIsOver(false);
    const sPage = parseInt(e.dataTransfer.getData("sourcePage"));
    const sIndex = parseInt(e.dataTransfer.getData("sourceIndex"));
    if (sPage !== pageNumber || sIndex !== slotIndex) {
      swapSlotContents(sPage, sIndex, pageNumber, slotIndex);
    }
  };

  const { main, decimal } = splitPrice(slot.product?.price);

  return (
    <div
      draggable={!!slot.product}
      onDragStart={handleDragStart}
      onDragOver={handleDragOver}
      onDragLeave={handleDragLeave}
      onDrop={handleDrop}
      className={`product-slot relative border transition-all duration-200 overflow-hidden h-full ${
        isOver ? "border-blue-500 bg-blue-50/30 scale-[0.98]" : "border-slate-200 bg-white"
      } ${slot.product ? "cursor-grab active:cursor-grabbing" : ""}`}
    >
      {/* HÜCRE NUMARASI (Sol Üst) - Her zaman görünür */}
      <div className="absolute top-0 left-0 z-20 p-1 text-[10px] font-black text-slate-300 pointer-events-none">
        {slotIndex + 1}
      </div>

      {slot.product ? (
        <div className="w-full h-full flex flex-col p-2 relative pointer-events-none">
          
          {/* FİYAT ZEMİNİ: %50 Genişlik, 10mm Boy, Tam Ortalı */}
          <div 
            className="absolute top-0 right-0 z-10 flex items-center justify-center bg-[#e60000] text-white shadow-sm overflow-hidden"
            style={{ 
              width: "50%", 
              height: "10mm", 
              borderBottomLeftRadius: "4px" 
            }}
          >
            <div className="flex items-start font-black">
              <span className="text-[20px] leading-[0.8] tracking-tighter">
                {main}<span className="inline-block scale-110">,</span>
              </span>
              <span className="text-[11px] leading-[0.8] ml-0.5">
                {decimal}
              </span>
            </div>
          </div>

          {/* Ürün Resmi */}
          <div className="flex-1 flex items-center justify-center min-h-0 bg-white mb-2 mt-6">
            {slot.product.image ? (
              <img src={slot.product.image} alt={slot.product.name} className="max-h-full max-w-full object-contain" />
            ) : (
              <div className="text-[8px] text-slate-300 uppercase italic">Resim Yok</div>
            )}
          </div>

          {/* Ürün Adı */}
          <div className="text-[10px] font-bold text-slate-800 leading-tight line-clamp-2 text-center">
            {slot.product.name}
          </div>
        </div>
      ) : (
        /* Boş Hücre Alanı */
        <div className="w-full h-full flex items-center justify-center pointer-events-none bg-slate-50/30">
           {/* Numara sol üstte olduğu için burada içerik boş kalabilir */}
        </div>
      )}
    </div>
  );
}

